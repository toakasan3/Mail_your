# MailGuard OSS - Environment Variables
# Copy this file to .env and fill in your values
# Production: Set these in Railway environment variables

# ============================================================
# REQUIRED - Generate using commands below
# ============================================================

# Telegram Bot Configuration
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (for admin access)
# Get from @userinfobot on Telegram
TELEGRAM_ADMIN_UID=

# Supabase Configuration
# Go to supabase.com -> Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # Use service_role key, NOT anon key

# Upstash Redis URL
# Go to upstash.com -> Create Database -> Copy Redis URL
REDIS_URL=rediss://default:password@endpoint.upstash.io:6379

# Encryption Key (exactly 64 hex characters = 32 bytes)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# JWT Secret (minimum 64 characters)
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=

# ============================================================
# OPTIONAL - Defaults shown
# ============================================================

# Environment (development or production)
ENV=development

# API Port
PORT=3000

# OTP Defaults
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=600
OTP_MAX_ATTEMPTS=5

# Rate Limits
RATE_LIMIT_EMAIL_PER_HOUR=10
RATE_LIMIT_API_KEY_PER_HOUR=1000
RATE_LIMIT_IP_PER_15MIN=100
RATE_LIMIT_PROJECT_PER_DAY=10000
RATE_LIMIT_SMTP_PER_DAY=500